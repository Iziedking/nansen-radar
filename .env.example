# =============================================================================
# NANSEN RADAR — Configuration
# Copy this file to .env and fill in what you need.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM PROVIDER — choose one, comment out the rest
# -----------------------------------------------------------------------------

# OPTION 1: Ollama (FREE — runs locally on your machine, no API cost)
# Install: winget install Ollama.Ollama  (Windows)
# Pull model: ollama pull llama3.2
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# OPTION 2: Anthropic Claude (paid, best quality)
# Get key: https://console.anthropic.com/
#LLM_PROVIDER=anthropic
#ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTION 3: Google Gemini (free tier available)
# Get key: https://aistudio.google.com/app/apikey
#LLM_PROVIDER=gemini
#GEMINI_API_KEY=your-gemini-key-here
#LLM_MODEL=gemini-1.5-flash

# OPTION 4: OpenRouter (free models available)
# Get key: https://openrouter.ai/keys
#LLM_PROVIDER=openrouter
#OPENROUTER_API_KEY=sk-or-your-key-here
#LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# OPTION 5: OpenClaw gateway (routes to Ollama/Gemini via local gateway)
# Install: npm install -g openclaw && openclaw onboard --install-daemon
#LLM_PROVIDER=openclaw

# -----------------------------------------------------------------------------
# NANSEN — API key configured via CLI, not here:
#   nansen login --api-key <your-nansen-key>
# -----------------------------------------------------------------------------
